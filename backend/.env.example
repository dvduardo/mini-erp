# Backend Environment Variables

# Server Port
PORT=5001
NODE_ENV=development

# Database
# Para desenvolvimento, deixe em branco para usar SQLite
# Para produção, use DATABASE_URL=postgresql://user:password@localhost:5432/database
DATABASE_URL=

# JWT Secret
# Mude isso em produção!
JWT_SECRET=sua-chave-super-secreta-mudeme-em-prod

# CORS
# Domínios permitidos (separados por vírgula)
CORS_ORIGIN=http://localhost:3000
