NODE_ENV=development
PORT=5001
HOST=127.0.0.1
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio
DATABASE_URL=
ALLOW_SQLITE_IN_PRODUCTION=false

# URL pública do frontend usada no link de redefinição de senha
APP_URL=http://localhost:5173

# Diretórios persistentes para uploads e backups
UPLOADS_DIR=
BACKUP_DIR=

# Backup automático
BACKUP_SCHEDULE_ENABLED=false
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=14
BACKUP_RUN_ON_START=false

# Upload opcional do backup para Google Drive
GOOGLE_DRIVE_BACKUP_ENABLED=false
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_SERVICE_ACCOUNT_JSON=

# Conta Gmail exclusiva do sistema
GMAIL_USER=seu-sistema@gmail.com
GMAIL_APP_PASSWORD=sua-senha-de-app
MAIL_FROM="La Dispensa <seu-sistema@gmail.com>"
