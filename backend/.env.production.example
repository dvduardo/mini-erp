# Backend Environment Variables - Production (Heroku / Railway)
# 
# IMPORTANTE: Nunca commite este arquivo com valores reais!
# Use as variáveis do painel do provedor para configurar produção.
#
# Exemplo Heroku:
# heroku config:set JWT_SECRET="sua-chave-segura" --app seu-app-heroku
# heroku config:set NODE_ENV=production --app seu-app-heroku
# heroku addons:create heroku-postgresql:essential-0 --app seu-app-heroku
#

# Server Port
# O provedor atribui dinamicamente via process.env.PORT
PORT=

# Environment
NODE_ENV=production

# Database
# Heroku e Railway fornecem DATABASE_URL automaticamente ao conectar PostgreSQL
DATABASE_URL=
ALLOW_SQLITE_IN_PRODUCTION=false

# Armazenamento persistente
# Aponte para um disco/volume persistente do provedor
UPLOADS_DIR=/data/uploads
BACKUP_DIR=/data/backups

# Backup automático
BACKUP_SCHEDULE_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=14
BACKUP_RUN_ON_START=false

# Upload opcional para Google Drive usando service account
GOOGLE_DRIVE_BACKUP_ENABLED=false
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# Alternativa ao par email/private key:
# GOOGLE_SERVICE_ACCOUNT_JSON=/app/secrets/google-service-account.json

# JWT Secret - MUDE PARA ALGO SEGURO EM PRODUÇÃO!
# Gere com: openssl rand -hex 32
JWT_SECRET=

# CORS
# Defina para o domínio da sua aplicação em produção
CORS_ORIGIN=https://seu-app-mini-erp.herokuapp.com

# App URL
# Usada em fluxos como recuperação de senha e links absolutos
APP_URL=https://seu-app-mini-erp.herokuapp.com
