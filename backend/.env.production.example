# Backend Environment Variables - Production (Heroku)
# 
# IMPORTANTE: Nunca commite este arquivo com valores reais!
# Use heroku config:set para configurar variáveis em produção.
#
# Exemplo:
# heroku config:set JWT_SECRET="sua-chave-segura" --app seu-app-heroku
# heroku config:set NODE_ENV=production --app seu-app-heroku
# heroku addons:create heroku-postgresql:essential-0 --app seu-app-heroku
#

# Server Port
# Heroku atribui dinamicamente via processo.env.PORT
PORT=

# Environment
NODE_ENV=production

# Database
# Heroku Postgres fornece automaticamente como DATABASE_URL
# Confirme com: heroku config:get DATABASE_URL --app seu-app-heroku
DATABASE_URL=

# JWT Secret - MUDE PARA ALGO SEGURO EM PRODUÇÃO!
# Gere com: openssl rand -hex 32
JWT_SECRET=

# CORS
# Defina para o domínio da sua aplicação em produção
CORS_ORIGIN=https://seu-app-mini-erp.herokuapp.com

# App URL
# Usada em fluxos como recuperação de senha e links absolutos
APP_URL=https://seu-app-mini-erp.herokuapp.com
